---
// 标签列表组件 — 精致胶囊样式
interface Props {
  tags: string[];
  /** 是否显示所有标签（默认不限制） */
  limit?: number;
}

const { tags, limit } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const displayTags = limit ? tags.slice(0, limit) : tags;
const remaining = limit ? tags.length - limit : 0;
---

<div class="flex flex-wrap gap-2">
  {displayTags.map((tag) => (
    <a
      href={`${baseUrl}tags/${tag}`}
      class="inline-flex items-center px-3 py-1 bg-ink-100/80 text-ink-600 rounded-md text-[13px] font-medium hover:bg-amber-50 hover:text-amber-700 transition-all duration-200"
    >
      {tag}
    </a>
  ))}
  {remaining > 0 && (
    <span class="inline-flex items-center px-2 py-1 text-[13px] text-ink-400">
      +{remaining}
    </span>
  )}
</div>
