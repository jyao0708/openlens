---
// PDF 下载按钮组件 — 醒目的 CTA 设计
interface Props {
  /** PDF 路径，如 /pdf/ai-toy-market-2026.pdf */
  href: string;
  /** 报告标题，用于下载文件名提示 */
  title: string;
}

const { href, title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// 拼接完整路径：base + pdf 路径（去掉 pdf 路径开头的 /，避免双斜杠）
const fullHref = `${baseUrl}${href.startsWith('/') ? href.slice(1) : href}`;
---

<div class="my-8">
  <a
    href={fullHref}
    target="_blank"
    rel="noopener noreferrer"
    class="group inline-flex items-center gap-3 px-6 py-3.5 bg-ink-900 text-white rounded-lg font-medium text-sm transition-all duration-200 hover:bg-ink-800 hover:shadow-lg hover:shadow-ink-900/20 hover:-translate-y-0.5 active:translate-y-0"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 transition-opacity">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
      <polyline points="7 10 12 15 17 10"></polyline>
      <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>
    下载完整 PDF 报告
    <span class="text-xs text-white/50 font-normal">PDF</span>
  </a>
</div>
