---
// PDF 下载按钮组件
interface Props {
  /** PDF 路径，如 /pdf/ai-toy-market-2026.pdf */
  href: string;
  /** 报告标题，用于下载文件名提示 */
  title: string;
}

const { href, title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// 拼接完整路径：base + pdf 路径（去掉 pdf 路径开头的 /，避免双斜杠）
const fullHref = `${baseUrl}${href.startsWith('/') ? href.slice(1) : href}`;
---

<div class="pdf-download">
  <a href={fullHref} target="_blank" rel="noopener noreferrer" class="download-btn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
      <polyline points="7 10 12 15 17 10"></polyline>
      <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>
    下载完整 PDF 报告
  </a>
</div>

<style>
  .pdf-download {
    margin-bottom: var(--space-xl);
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background-color: var(--color-primary);
    color: #ffffff;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    transition: background-color 0.2s ease;
  }

  .download-btn:hover {
    background-color: var(--color-primary-hover);
    color: #ffffff;
  }

  .download-btn svg {
    flex-shrink: 0;
  }
</style>
