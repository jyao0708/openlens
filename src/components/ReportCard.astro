---
interface Props {
  title: string;
  slug: string;
  source: string;
  date: Date;
  category: string;
  tags: string[];
  summary: string;
}

// 报告卡片组件 — 编辑风格，精致卡片设计（含默认阴影）
const { title, slug, source, date, category, tags, summary } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group relative bg-white rounded-xl border border-ink-200/60 p-6 transition-all duration-300 card-shadow hover:card-shadow-hover hover:border-ink-300 hover:-translate-y-0.5 flex flex-col h-full">
  <!-- 顶部装饰线 -->
  <div class="absolute top-0 left-6 right-6 h-[2px] bg-gradient-to-r from-amber-500 via-amber-400 to-transparent rounded-b opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

  <!-- 顶部：分类 + 日期 -->
  <div class="flex items-center justify-between mb-3.5">
    <a
      href={`${baseUrl}categories/${category}`}
      class="relative z-10 inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-amber-600 hover:text-amber-500 transition-colors"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-amber-500 ring-[3px] ring-amber-50"></span>
      {category}
    </a>
    <time datetime={date.toISOString().split('T')[0]} class="text-[11px] text-ink-400 tabular-nums font-medium">
      {formattedDate}
    </time>
  </div>

  <!-- 标题 -->
  <h3 class="font-display text-[1.05rem] font-bold leading-snug text-ink-900 mb-2.5 tracking-tight line-clamp-2 group-hover:text-ink-800">
    <a href={`${baseUrl}reports/${slug}`} class="after:absolute after:inset-0 hover:text-amber-700 transition-colors duration-200">
      {title}
    </a>
  </h3>

  <!-- 摘要 -->
  <p class="text-[0.82rem] text-ink-500 leading-[1.7] mb-auto line-clamp-3">
    {summary}
  </p>

  <!-- 底部：来源 + 标签 -->
  <div class="flex items-center justify-between gap-3 pt-4 mt-4 border-t border-ink-100/80">
    <span class="text-[11px] font-medium text-ink-400 truncate max-w-[130px]">
      <span class="text-ink-300 mr-0.5">by</span> {source}
    </span>
    <div class="flex gap-1.5 flex-shrink-0">
      {tags.slice(0, 2).map((tag) => (
        <a href={`${baseUrl}tags/${tag}`} class="relative z-10 inline-block px-2 py-0.5 bg-ink-50 text-ink-500 rounded text-[10px] font-semibold border border-ink-200/70 hover:bg-amber-50 hover:text-amber-700 hover:border-amber-200 transition-all duration-200">
          {tag}
        </a>
      ))}
      {tags.length > 2 && (
        <span class="inline-block px-1.5 py-0.5 text-[10px] text-ink-400 font-medium">+{tags.length - 2}</span>
      )}
    </div>
  </div>
</article>
