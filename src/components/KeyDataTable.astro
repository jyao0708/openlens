---
// 关键数据网格组件 — 数据驱动的视觉卡片
interface Props {
  data: Array<{
    metric: string;
    value: string;
    note?: string;
  }>;
}

const { data } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  {data.map((item, i) => (
    <div class="relative bg-white border border-ink-200/70 rounded-xl p-5 hover:shadow-md hover:shadow-ink-900/5 transition-all duration-200 overflow-hidden">
      <!-- 装饰角标 -->
      <div class="absolute top-0 right-0 w-16 h-16 -mr-8 -mt-8 bg-amber-50 rounded-full opacity-60"></div>
      <!-- 数值 -->
      <div class="relative">
        <div class="font-display text-2xl font-bold text-ink-900 tracking-tight mb-1.5">
          {item.value}
        </div>
        <div class="text-sm text-ink-600 font-medium leading-snug">
          {item.metric}
        </div>
        {item.note && (
          <div class="text-xs text-ink-400 mt-2 leading-relaxed">
            {item.note}
          </div>
        )}
      </div>
    </div>
  ))}
</div>
