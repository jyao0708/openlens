---
import { CATEGORIES } from '../content.config';

// 分类导航组件 — 胶囊式标签切换（完善的 active/inactive 状态）
interface Props {
  /** 当前激活的分类 */
  current?: string;
}

const { current } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<nav class="flex flex-wrap gap-2.5 mb-10">
  <a
    href={baseUrl}
    class:list={[
      'inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold transition-all duration-250',
      !current
        ? 'bg-ink-900 text-white shadow-lg shadow-ink-900/25 ring-1 ring-ink-800'
        : 'bg-white text-ink-500 border border-ink-200 card-shadow hover:border-amber-300 hover:text-amber-700 hover:bg-amber-50 hover:shadow-md'
    ]}
  >
    全部
  </a>
  {CATEGORIES.map((cat) => (
    <a
      href={`${baseUrl}categories/${cat}`}
      class:list={[
        'inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold transition-all duration-250',
        current === cat
          ? 'bg-ink-900 text-white shadow-lg shadow-ink-900/25 ring-1 ring-ink-800'
          : 'bg-white text-ink-500 border border-ink-200 card-shadow hover:border-amber-300 hover:text-amber-700 hover:bg-amber-50 hover:shadow-md'
      ]}
    >
      {cat}
    </a>
  ))}
</nav>
