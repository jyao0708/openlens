---
import { CATEGORIES } from '../content.config';

// 分类导航组件 — 胶囊式标签切换（完善的 active/inactive 状态）
interface Props {
  /** 当前激活的分类 */
  current?: string;
}

const { current } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<nav class="flex flex-wrap gap-2 mb-7">
  <a
    href={baseUrl}
    class:list={[
      'inline-flex items-center px-3.5 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200',
      !current
        ? 'bg-ink-900 text-white shadow-md shadow-ink-900/20'
        : 'bg-white text-ink-500 border border-ink-200/80 hover:border-amber-300 hover:text-amber-700 hover:bg-amber-50'
    ]}
  >
    全部
  </a>
  {CATEGORIES.map((cat) => (
    <a
      href={`${baseUrl}categories/${cat}`}
      class:list={[
        'inline-flex items-center px-3.5 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200',
        current === cat
          ? 'bg-ink-900 text-white shadow-md shadow-ink-900/20'
          : 'bg-white text-ink-500 border border-ink-200/80 hover:border-amber-300 hover:text-amber-700 hover:bg-amber-50'
      ]}
    >
      {cat}
    </a>
  ))}
</nav>
