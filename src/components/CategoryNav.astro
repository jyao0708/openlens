---
// 分类导航组件 — 胶囊式标签切换
import { CATEGORIES } from '../content.config';

interface Props {
  /** 当前激活的分类 */
  current?: string;
}

const { current } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<nav class="flex flex-wrap gap-2 mb-10">
  <a
    href={baseUrl}
    class:list={[
      'inline-flex items-center px-4 py-2 rounded-full text-sm font-medium transition-all duration-200',
      !current
        ? 'bg-ink-900 text-white shadow-md shadow-ink-900/20'
        : 'bg-white text-ink-500 border border-ink-200 hover:border-ink-400 hover:text-ink-700 hover:shadow-sm'
    ]}
  >
    全部
  </a>
  {CATEGORIES.map((cat) => (
    <a
      href={`${baseUrl}categories/${cat}`}
      class:list={[
        'inline-flex items-center px-4 py-2 rounded-full text-sm font-medium transition-all duration-200',
        current === cat
          ? 'bg-ink-900 text-white shadow-md shadow-ink-900/20'
          : 'bg-white text-ink-500 border border-ink-200 hover:border-ink-400 hover:text-ink-700 hover:shadow-sm'
      ]}
    >
      {cat}
    </a>
  ))}
</nav>
