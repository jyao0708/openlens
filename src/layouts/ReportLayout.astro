---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import PdfDownload from '../components/PdfDownload.astro';
import KeyDataTable from '../components/KeyDataTable.astro';

// 报告详情页布局 — 长文阅读优化的编辑排版
interface Props {
  title: string;
  source: string;
  date: Date;
  pageCount?: number;
  category: string;
  tags: string[];
  summary: string;
  keyFindings: string[];
  keyData?: Array<{ metric: string; value: string; note?: string }>;
  pdf: string;
}

const {
  title,
  source,
  date,
  pageCount,
  category,
  tags,
  summary,
  keyFindings,
  keyData,
  pdf,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;

// 格式化日期
const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={summary}>
  <!-- 报告头部 Hero -->
  <div class="bg-ink-900 relative overflow-hidden">
    <!-- 背景装饰（CSS 类替代内联 SVG，避免 esbuild 报错） -->
    <div class="absolute inset-0 hero-texture"></div>
    <div class="absolute inset-0 grid-pattern"></div>

    <!-- 光晕装饰 -->
    <div class="absolute top-1/2 left-1/2 w-[600px] h-[400px] rounded-full bg-amber-500/15 blur-[100px] animate-glow-pulse"></div>
    <div class="absolute -bottom-32 -right-32 w-[400px] h-[300px] bg-amber-500/8 rounded-full blur-[80px]"></div>

    <!-- 底部过渡渐变 -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-paper to-transparent"></div>

    <div class="relative max-w-3xl mx-auto px-6 pt-16 pb-24">
      <!-- 面包屑 -->
      <div class="flex items-center gap-2.5 mb-8 animate-fade-up">
        <a href={baseUrl} class="text-xs font-medium text-ink-400 hover:text-white transition-colors duration-200">首页</a>
        <span class="text-ink-600">/</span>
        <a href={`${baseUrl}categories/${category}`} class="text-xs font-medium text-amber-400 hover:text-amber-300 transition-colors duration-200">{category}</a>
      </div>

      <!-- 标题 -->
      <h1 class="font-display text-3xl md:text-[2.5rem] font-extrabold text-white leading-tight tracking-tight mb-7 animate-fade-up delay-1">
        {title}
      </h1>

      <!-- 元信息 -->
      <div class="flex flex-wrap items-center gap-4 text-sm animate-fade-up delay-2">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-300">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"></path>
              <circle cx="12" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"></circle>
            </svg>
          </div>
          <span class="text-ink-300 font-medium">{source}</span>
        </div>
        <span class="w-1 h-1 rounded-full bg-ink-600"></span>
        <time datetime={date.toISOString().split('T')[0]} class="text-ink-400 font-medium">
          {formattedDate}
        </time>
        {pageCount && (
          <>
            <span class="w-1 h-1 rounded-full bg-ink-600"></span>
            <span class="text-ink-400">{pageCount} 页</span>
          </>
        )}
      </div>
    </div>
  </div>

  <!-- 正文区域 -->
  <article class="max-w-3xl mx-auto px-6 -mt-12 relative z-10">
    <!-- 摘要卡片 -->
    <div class="bg-white rounded-xl border border-ink-200/80 p-8 md:p-10 shadow-depth mb-12 animate-fade-up delay-3">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-1 h-7 bg-gradient-to-b from-amber-500 to-amber-300 rounded-full"></div>
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-ink-400">摘要</span>
      </div>
      <p class="text-ink-700 leading-[1.9] text-[15px]">{summary}</p>
      <div class="mt-7 pt-6 border-t border-ink-100">
        <TagList tags={tags} />
      </div>
    </div>

    <!-- PDF 下载 -->
    <PdfDownload href={pdf} title={title} />

    <!-- 核心结论 -->
    <section class="mb-14">
      <h2 class="font-display text-xl font-bold text-ink-900 mb-7 flex items-center gap-3">
        <span class="w-10 h-[3px] bg-gradient-to-r from-amber-500 to-amber-300 rounded-full"></span>
        核心结论
      </h2>
      <div class="space-y-4">
        {keyFindings.map((finding, i) => (
          <div class="flex gap-4 p-5 bg-white rounded-xl border border-ink-200/70 card-shadow hover:card-shadow-hover transition-all duration-300 group">
            <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-ink-900 text-white text-xs font-bold flex items-center justify-center group-hover:bg-amber-500 transition-colors duration-300">
              {i + 1}
            </span>
            <p class="text-sm text-ink-700 leading-relaxed pt-1">{finding}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 关键数据 -->
    {keyData && keyData.length > 0 && (
      <section class="mb-14">
        <h2 class="font-display text-xl font-bold text-ink-900 mb-7 flex items-center gap-3">
          <span class="w-10 h-[3px] bg-gradient-to-r from-amber-500 to-amber-300 rounded-full"></span>
          关键数据
        </h2>
        <KeyDataTable data={keyData} />
      </section>
    )}

    <!-- 正文内容（Markdown 渲染） -->
    <section class="prose mb-16 pb-16 border-b-2 border-ink-200/60">
      <slot />
    </section>

    <!-- 返回首页 -->
    <div class="text-center pb-20">
      <a
        href={baseUrl}
        class="group inline-flex items-center gap-2.5 px-6 py-3 text-sm font-semibold text-ink-500 hover:text-ink-900 bg-white border border-ink-200 rounded-xl card-shadow hover:card-shadow-hover transition-all duration-300"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:-translate-x-1">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        返回所有报告
      </a>
    </div>
  </article>
</BaseLayout>
