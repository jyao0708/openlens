---
// 分类页面 — 展示某个分类下的所有报告
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../content.config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportCard from '../../components/ReportCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';

// 静态路径生成：为每个分类生成一个页面
export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

// 获取该分类下的非草稿报告，按日期倒序
const reports = (await getCollection('reports', ({ data }) =>
  !data.draft && data.category === category
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`${category} - 分类`} description={`${category}分类下的研究报告`}>
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <!-- 页面标题 -->
    <div class="mb-8 animate-fade-up">
      <h1 class="font-display text-3xl font-bold text-ink-900 tracking-tight mb-2">{category}</h1>
      <p class="text-ink-500">共 {reports.length} 篇报告</p>
    </div>

    <CategoryNav current={category} />

    {reports.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-ink-500 font-medium">该分类暂无报告</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {reports.map((report, i) => (
          <div class:list={['animate-fade-up', `delay-${Math.min(i + 1, 8)}`]}>
            <ReportCard
              title={report.data.title}
              slug={report.data.slug}
              source={report.data.source}
              date={report.data.date}
              category={report.data.category}
              tags={report.data.tags}
              summary={report.data.summary}
            />
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
