---
// 标签页面 — 展示包含某个标签的所有报告
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportCard from '../../components/ReportCard.astro';

// 静态路径生成：收集所有不重复的标签
export async function getStaticPaths() {
  const allReports = await getCollection('reports', ({ data }) => !data.draft);
  const allTags = [...new Set(allReports.flatMap((r) => r.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// 获取包含该标签的非草稿报告，按日期倒序
const reports = (await getCollection('reports', ({ data }) =>
  !data.draft && data.tags.includes(tag)
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`#${tag} - 标签`} description={`包含标签「${tag}」的研究报告`}>
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <!-- 页面标题 -->
    <div class="mb-10 animate-fade-up">
      <a href={baseUrl} class="text-xs text-ink-400 hover:text-ink-700 transition-colors mb-4 inline-block">&larr; 返回全部</a>
      <h1 class="font-display text-3xl font-bold text-ink-900 tracking-tight mb-2">
        <span class="text-ink-300 font-normal">#</span>{tag}
      </h1>
      <p class="text-ink-500">共 {reports.length} 篇报告</p>
    </div>

    {reports.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-ink-500 font-medium">该标签暂无报告</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {reports.map((report, i) => (
          <div class:list={['animate-fade-up', `delay-${Math.min(i + 1, 8)}`]}>
            <ReportCard
              title={report.data.title}
              slug={report.data.slug}
              source={report.data.source}
              date={report.data.date}
              category={report.data.category}
              tags={report.data.tags}
              summary={report.data.summary}
            />
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
