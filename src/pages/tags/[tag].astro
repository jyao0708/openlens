---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportCard from '../../components/ReportCard.astro';

// 静态路径生成：收集所有不重复的标签
export async function getStaticPaths() {
  const allReports = await getCollection('reports', ({ data }) => !data.draft);
  const allTags = [...new Set(allReports.flatMap((r) => r.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// 获取包含该标签的非草稿报告，按日期倒序
const reports = (await getCollection('reports', ({ data }) =>
  !data.draft && data.tags.includes(tag)
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`#${tag} - 标签`} description={`包含标签「${tag}」的研究报告`}>
  <!-- 标签页面头部：轻量 Hero -->
  <div class="bg-ink-900 relative overflow-hidden">
    <!-- 背景纹理 -->
    <div class="absolute inset-0 hero-texture"></div>
    <!-- 光晕 -->
    <div class="absolute top-1/2 left-1/2 w-[500px] h-[300px] rounded-full bg-amber-500/12 blur-[80px] animate-glow-pulse"></div>
    <!-- 底部过渡 -->
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-paper to-transparent"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-14 md:py-20">
      <div class="animate-fade-up">
        <!-- 面包屑 -->
        <div class="flex items-center gap-2 mb-6">
          <a href={baseUrl} class="text-xs font-medium text-ink-400 hover:text-white transition-colors">首页</a>
          <span class="text-ink-600">/</span>
          <span class="text-xs font-medium text-amber-400">标签</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-3">
          <span class="text-amber-400/60 font-normal mr-1">#</span>{tag}
        </h1>
        <p class="text-ink-400 font-medium">共 <span class="text-amber-400 font-bold">{reports.length}</span> 篇相关报告</p>
      </div>
    </div>
  </div>

  <section class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <!-- 返回按钮 -->
    <div class="mb-8 animate-fade-up">
      <a href={baseUrl} class="group inline-flex items-center gap-2 text-sm font-medium text-ink-400 hover:text-ink-700 transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:-translate-x-1">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        返回全部报告
      </a>
    </div>

    {reports.length === 0 ? (
      <div class="text-center py-24">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-ink-100 flex items-center justify-center card-shadow">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ink-400">
            <path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <p class="text-ink-600 font-semibold text-lg mb-2">该标签暂无报告</p>
        <p class="text-sm text-ink-400">更多内容即将上线</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-7">
        {reports.map((report, i) => (
          <div class:list={['animate-fade-up', `delay-${Math.min(i + 1, 8)}`]}>
            <ReportCard
              title={report.data.title}
              slug={report.data.slug}
              source={report.data.source}
              date={report.data.date}
              category={report.data.category}
              tags={report.data.tags}
              summary={report.data.summary}
            />
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
