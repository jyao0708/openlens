---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportCard from '../components/ReportCard.astro';
import CategoryNav from '../components/CategoryNav.astro';

// 获取所有非草稿报告，按日期倒序排列
const allReports = (await getCollection('reports', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const reportCount = allReports.length;
---

<BaseLayout title="首页">
  <!-- Hero 区域：居中布局，更强烈的视觉冲击 -->
  <section class="relative overflow-hidden bg-ink-900">
    <!-- 背景纹理（CSS 类替代内联 SVG） -->
    <div class="absolute inset-0 hero-texture"></div>
    <!-- 网格装饰 -->
    <div class="absolute inset-0 grid-pattern"></div>

    <!-- 主光晕：更大更亮 -->
    <div class="absolute top-1/2 left-1/2 w-[800px] h-[500px] rounded-full bg-amber-500/20 blur-[100px] animate-glow-pulse"></div>
    <!-- 辅助光晕 -->
    <div class="absolute -top-20 -right-20 w-[400px] h-[400px] rounded-full bg-amber-400/8 blur-[80px]"></div>
    <div class="absolute -bottom-32 -left-32 w-[300px] h-[300px] rounded-full bg-amber-600/10 blur-[60px]"></div>

    <!-- 底部渐变过渡 -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-paper to-transparent"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-36">
      <!-- 居中布局 -->
      <div class="max-w-3xl mx-auto text-center animate-fade-up">
        <!-- 状态标签 -->
        <div class="inline-flex items-center gap-2.5 px-4 py-1.5 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full mb-8">
          <div class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></div>
          <span class="text-xs font-semibold text-amber-300 tracking-wider uppercase">{reportCount} 份深度报告已入库</span>
        </div>

        <!-- 主标题 -->
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight mb-6">
          从报告中<br class="sm:hidden" />
          <span class="relative inline-block">
            <span class="text-amber-400">提炼信号</span>
            <span class="absolute -bottom-1 left-0 right-0 h-[3px] bg-amber-500/50 rounded-full"></span>
          </span>
        </h1>

        <!-- 副标题 -->
        <p class="text-base sm:text-lg text-ink-300 leading-relaxed max-w-xl mx-auto animate-fade-up delay-1 mb-10">
          AI 驱动的行业洞察平台。自动解析 PDF 研究报告，提取核心结论与关键数据，构建可检索的知识库。
        </p>

        <!-- 装饰性分割线 -->
        <div class="flex items-center justify-center gap-3 animate-fade-up delay-2">
          <div class="w-12 h-px bg-ink-600"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div>
          <div class="w-12 h-px bg-ink-600"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 报告列表 -->
  <section class="max-w-6xl mx-auto px-6 py-14 md:py-20">
    <!-- 分类导航区域 -->
    <div class="mb-2 animate-fade-up">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="font-display text-xl font-bold text-ink-900 tracking-tight">研究报告</h2>
        <div class="flex-1 h-px bg-ink-200"></div>
        <span class="text-xs font-medium text-ink-400 tracking-wide tabular-nums">{reportCount} 篇</span>
      </div>
    </div>

    <CategoryNav />

    {allReports.length === 0 ? (
      <div class="text-center py-24">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-ink-100 flex items-center justify-center card-shadow">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ink-400">
            <path d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <p class="text-ink-600 font-semibold text-lg mb-2">暂无报告内容</p>
        <p class="text-sm text-ink-400 max-w-sm mx-auto leading-relaxed">将 PDF 放入 inbox/pdf/ 目录，使用 AI 分析后即可发布。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-7">
        {allReports.map((report, i) => (
          <div class:list={['animate-fade-up', `delay-${Math.min(i + 1, 8)}`]}>
            <ReportCard
              title={report.data.title}
              slug={report.data.slug}
              source={report.data.source}
              date={report.data.date}
              category={report.data.category}
              tags={report.data.tags}
              summary={report.data.summary}
            />
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
